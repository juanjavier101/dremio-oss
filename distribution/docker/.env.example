# ─── Image ────────────────────────────────────────────────────────────────────
# Dremio OSS release tarball URL — required to build the image.
# Example: https://download.dremio.com/community-server/<version>/dremio-community-<version>.tar.gz
DOWNLOAD_URL=

# Tag applied to the built image. Used by docker-compose.prod.yml.
# Build: docker build --build-arg DOWNLOAD_URL=<URL> -t dremio-oss:<tag> .
DREMIO_IMAGE_TAG=local

# ─── Data paths (production) ──────────────────────────────────────────────────
# Root directory on the host where all node data is stored.
# Run `sudo ./scripts/setup-host.sh` to create and chown these directories.
DATA_ROOT=/opt/dremio/data

# ─── Coordinator memory ───────────────────────────────────────────────────────
# Coordinator uses more heap for catalog metadata and query planning.
# Tune based on available VM RAM. Heap + Direct should not exceed available RAM.
# Recommended: leave ~2 GB headroom for the OS and JVM overhead.
COORDINATOR_HEAP_MB=8192
COORDINATOR_DIRECT_MB=4096

# ─── Executor memory ──────────────────────────────────────────────────────────
# Executors use less heap but more direct memory for query processing.
# These values apply to all three executor nodes.
EXECUTOR_HEAP_MB=4096
EXECUTOR_DIRECT_MB=8192
